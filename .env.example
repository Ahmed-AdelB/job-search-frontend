# Frontend Environment Variables - Template for Deployment
# Author: Ahmed Adel Bakr Alderai
#
# This file documents all public environment variables used by the Next.js frontend.
# Copy this file to .env.local (development) or .env.production (production).
#
# IMPORTANT NOTES:
# 1. All NEXT_PUBLIC_* variables are baked into the production build
# 2. These variables are available in the browser and visible in network requests
# 3. Production variables are set during docker-compose build via environment substitution
# 4. The frontend uses these variables to route API requests to the backend
#
# ARCHITECTURE:
# - Caddyfile.prod: Routes {$DOMAIN}/api/* → jobsearch-web:8082 (FastAPI)
# - Frontend middleware.ts: Proxies /api/* requests to NEXT_PUBLIC_API_URL
# - api-client.ts: Uses NEXT_PUBLIC_API_URL for all HTTP requests
# - Docker Compose: Sets NEXT_PUBLIC_API_URL from DOMAIN environment variable

# =============================================================================
# REQUIRED VARIABLES
# =============================================================================

# API URL for backend communication (REQUIRED)
#
# Development: http://localhost:8082 (FastAPI backend)
# Production: https://${DOMAIN} (proxied through Caddy)
#
# Format:
# - Must be an absolute URL (http:// or https://)
# - Must NOT have trailing slash
# - Examples: http://localhost:8082, https://api.jobsearch.com, https://jobsearch.example.com
#
# Usage in Code:
# - frontend/src/lib/api-client.ts: Constructs API endpoints
# - frontend/src/middleware.ts: Routes /api/* to backend
# - frontend/src/hooks/*.ts: All API hooks use this URL
#
NEXT_PUBLIC_API_URL=http://localhost:8082

# =============================================================================
# DEPLOYMENT CONFIGURATION
# =============================================================================

# For production Docker deployment:
# 1. Set DOMAIN environment variable before running docker-compose:
#    export DOMAIN=jobsearch.example.com
#
# 2. The docker-compose.prod.yml will:
#    a) Set NEXT_PUBLIC_API_URL=https://${DOMAIN} in the frontend build
#    b) Configure Caddy to proxy /api/* to the FastAPI backend
#    c) Serve the frontend on the same domain
#
# 3. Example deployment command:
#    DOMAIN=jobsearch.example.com docker-compose -f docker-compose.prod.yml up -d

# =============================================================================
# BUILD AND RUNTIME BEHAVIOR
# =============================================================================

# Next.js Build Time:
# - NEXT_PUBLIC_API_URL is embedded in the compiled JavaScript
# - Changing this variable requires a rebuild
# - Build output is static and baked for the specified domain
#
# Runtime Behavior:
# - Middleware (middleware.ts):
#   * Intercepts /api/* requests from the browser
#   * Rewrites them to NEXT_PUBLIC_API_URL backend
#   * Adds proper Host and X-Forwarded-* headers
#
# - API Client (api-client.ts):
#   * Uses NEXT_PUBLIC_API_URL as the base for fetch calls
#   * Sends Authorization headers with JWT tokens
#   * Handles 401 responses by redirecting to /login
#
# =============================================================================
# TROUBLESHOOTING
# =============================================================================

# Issue: "Cannot reach API" or 404 on /api endpoints
# Solution: Verify NEXT_PUBLIC_API_URL matches your backend URL
#           Ensure Caddy/reverse proxy is correctly configured
#           Check CORS headers on API response
#
# Issue: Frontend builds but API calls fail in production
# Cause: NEXT_PUBLIC_API_URL was not set during docker build
# Solution: Rebuild with correct DOMAIN variable set
#           docker-compose.prod.yml automatically passes DOMAIN to the build
#
# Issue: NEXT_PUBLIC_API_URL not taking effect
# Cause: Variable not prefixed with NEXT_PUBLIC_
# Solution: Only variables starting with NEXT_PUBLIC_ are available to browser
#           Server-only variables should not have this prefix
#
# =============================================================================
# REFERENCE
# =============================================================================

# API Endpoints Used by Frontend:
# GET  /api/auth/me                    - Current user
# POST /api/auth/login                 - User login
# POST /api/auth/logout                - User logout
# GET  /api/jobs                       - List jobs
# POST /api/jobs/import                - Import job CSV
# GET  /api/contacts                   - List contacts
# POST /api/contacts/import            - Import contacts
# PATCH /api/applications/{id}         - Update application status
# GET  /api/target-list                - Fetch target companies
# POST /api/target-list/import         - Import target list
# GET  /api/profile                    - User profile
# PATCH /api/profile                   - Update profile
# POST /api/onboarding/cv              - Upload CV
# And more... see src/hooks/*.ts for complete list
